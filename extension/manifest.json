{
  "manifest_version": 3,
  "name": "Bandpass",
  "version": "1.0.0",
  "description": "Connect your Bandcamp account to Bandpass for filtered feed browsing and discovery.",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://*.bandcamp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["connector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
